# Example PKGBUILD for Arch Linux (AUR). Copy to PKGBUILD, set pkgver/sha256sums from a release tarball.
# Maintainer: replace with your AUR username.

pkgname=k8pk
pkgver=1.14.14
pkgrel=1
pkgdesc="Kubernetes context picker — cross-terminal context/namespace switcher"
arch=('x86_64' 'aarch64')
url="https://github.com/vee-sh/k8pk"
license=('MIT')
depends=('glibc')
makedepends=('cargo')
source=("https://github.com/vee-sh/k8pk/releases/download/v${pkgver}/k8pk-v${pkgver}-${CARCH}-unknown-linux-gnu.tar.gz")
# sha256sums=('REPLACE_ME')

build() {
  cd "k8pk-v${pkgver}-${CARCH}-unknown-linux-gnu"
  :
}

package() {
  cd "k8pk-v${pkgver}-${CARCH}-unknown-linux-gnu"
  install -Dm755 k8pk "${pkgdir}/usr/bin/k8pk"
  if [ -d share/man/man1 ]; then
    install -Dm644 share/man/man1/*.1 -t "${pkgdir}/usr/share/man/man1/"
  fi
}
